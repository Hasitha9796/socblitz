# ─────────────────────────────────────────────────────────────────────────────
# SocBlitz — Complete environment configuration
# All URLs use Docker service names — no external services needed.
# Run:  sed -i "s/CHANGE_ME_32/$(openssl rand -hex 32)/" .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SocBlitz application ──────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_ME_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIRST_ADMIN_EMAIL=admin@socblitz.local
FIRST_ADMIN_PASSWORD=SocBlitz@Admin1!

# ── PostgreSQL (internal) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=socblitz
POSTGRES_USER=socblitz
POSTGRES_PASSWORD=SocBlitz@Postgres1

# ── Redis (internal) ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=SocBlitz@Redis1
REDIS_DB=0

# ── MinIO (internal) ──────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=socblitz
MINIO_ROOT_PASSWORD=SocBlitz@Minio1
MINIO_SECURE=false
MINIO_BUCKET_CASES=socblitz-cases
MINIO_BUCKET_REPORTS=socblitz-reports
MINIO_BUCKET_ARTIFACTS=socblitz-artifacts

# ── ClickHouse (analytics store — replaces the Wazuh Indexer) ─────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=socblitz
CLICKHOUSE_PASSWORD=SocBlitz@Click1

# ── SocBlitz Engine (custom detection engine — replaces the Wazuh manager) ────
ENGINE_URL=http://engine:8090

# ── Wazuh (internal — bundled in this compose) ────────────────────────────────
WAZUH_MANAGER_URL=https://wazuh-manager:55000
WAZUH_MANAGER_USER=wazuh-wui
WAZUH_MANAGER_PASSWORD=MyS3cr37P450r.*-

# ── Threat Intelligence (optional — add API keys when ready) ──────────────────
VIRUSTOTAL_API_KEY=
MISP_URL=
MISP_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── Dark Web / leak monitoring (optional — each source activates when its key ──
# is set; with none set, HIBP domain search + the LeakCheck public email index
# still work keyless. See the Dark Web page.)
HIBP_API_KEY=
INTELX_API_KEY=
DEHASHED_EMAIL=
DEHASHED_API_KEY=
LEAKCHECK_API_KEY=
DARKWEB_SCAN_INTERVAL_HOURS=6

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Local Ollama (bundled in this compose) powers the agentic dashboard by default.
# OLLAMA_MODEL is what the ollama container pulls; LOCAL_LLM_MODEL must match.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
LOCAL_LLM_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_EMBED_MODEL=nomic-embed-text

# ── Notifications (optional) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=socblitz@yourorg.com
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── SocBlitz unified agent deployment ────────────────────────────────────────
# Key endpoints must present to download the agent installer during enrolment.
# Generate with: openssl rand -hex 16
AGENT_ENROLL_KEY=change-me
# Optional: address endpoints use to reach this server (default: auto from request)
AGENT_PUBLIC_HOST=
