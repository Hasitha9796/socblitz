# ─────────────────────────────────────────────────────────────────────────────
# SocBlitz — Complete environment configuration
# All URLs use Docker service names — no external services needed.
# Run:  sed -i "s/CHANGE_ME_32/$(openssl rand -hex 32)/" .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SocBlitz application ──────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_ME_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIRST_ADMIN_EMAIL=admin@socblitz.local
FIRST_ADMIN_PASSWORD=SocBlitz@Admin1!

# ── PostgreSQL (internal) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=socblitz
POSTGRES_USER=socblitz
POSTGRES_PASSWORD=SocBlitz@Postgres1

# ── Redis (internal) ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=SocBlitz@Redis1
REDIS_DB=0

# ── MinIO (internal) ──────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=socblitz
MINIO_ROOT_PASSWORD=SocBlitz@Minio1
MINIO_SECURE=false
MINIO_BUCKET_CASES=socblitz-cases
MINIO_BUCKET_REPORTS=socblitz-reports
MINIO_BUCKET_ARTIFACTS=socblitz-artifacts

# ── Wazuh (internal — bundled in this compose) ────────────────────────────────
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=SecretPassword

WAZUH_MANAGER_URL=https://wazuh-manager:55000
WAZUH_MANAGER_USER=wazuh-wui
WAZUH_MANAGER_PASSWORD=MyS3cr37P450r.*-

# ── Graylog (internal — bundled in this compose) ──────────────────────────────
GRAYLOG_URL=http://graylog:9000
GRAYLOG_API_KEY=
# Leave blank on first boot. After Graylog starts, go to:
# http://YOUR_SERVER_IP:9000 → System → Users → Admin → API tokens → create one
# Then paste it here and run: docker compose restart backend worker beat

GRAYLOG_PASSWORD_SECRET=yourmustchangethispasswordsecret
# SHA2 hash of your Graylog admin password. Default below = "admin"
# To set a new password:  echo -n "yourpassword" | sha256sum
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# ── Grafana (internal — bundled in this compose) ──────────────────────────────
GRAFANA_URL=http://grafana:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=SocBlitz@Grafana1

# ── InfluxDB (internal — bundled in this compose) ─────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=socblitz-influx-token-change-me
INFLUXDB_ORG=socblitz
INFLUXDB_BUCKET=socblitz
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=SocBlitz@Influx1

# ── Threat Intelligence (optional — add API keys when ready) ──────────────────
VIRUSTOTAL_API_KEY=
MISP_URL=
MISP_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── AI / LLM (optional) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=

# ── Notifications (optional) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=socblitz@yourorg.com
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
