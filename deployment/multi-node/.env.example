# ─────────────────────────────────────────────────────────────────────────────
# SocBlitz MULTI-NODE — environment configuration
# Copy to .env, then replace every CHANGE_ME:
#   sed -i "s/CHANGE_ME_32/$(openssl rand -hex 32)/" .env
# There are NO default passwords in this deployment — compose refuses to start
# until the required secrets are set.
# ─────────────────────────────────────────────────────────────────────────────

# ── SocBlitz application ──────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_ME_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIRST_ADMIN_EMAIL=admin@socblitz.local
FIRST_ADMIN_PASSWORD=CHANGE_ME

# ── PostgreSQL (internal) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=socblitz
POSTGRES_USER=socblitz
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis (internal) ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# ── MinIO (internal) ──────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=socblitz
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_SECURE=false
MINIO_BUCKET_CASES=socblitz-cases
MINIO_BUCKET_REPORTS=socblitz-reports
MINIO_BUCKET_ARTIFACTS=socblitz-artifacts

# ── Wazuh cluster (internal — this compose) ───────────────────────────────────
# The backend spreads reads across the indexer cluster; any node works as the
# entry point. The manager API lives on the master only.
WAZUH_INDEXER_URL=https://wazuh-indexer-1:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME

WAZUH_MANAGER_URL=https://wazuh-master:55000
WAZUH_MANAGER_USER=wazuh-wui
WAZUH_MANAGER_PASSWORD=CHANGE_ME

# Indexer JVM heap per node — set to ~50% of the RAM you can give each node,
# never above 31g. 3 nodes × this heap must fit in host RAM with room to spare.
INDEXER_HEAP=-Xms4g -Xmx4g

# ── MISP ──────────────────────────────────────────────────────────────────────
MISP_ADMIN_EMAIL=admin@admin.test
MISP_ADMIN_PASSWORD=CHANGE_ME
MISP_API_KEY=CHANGE_ME_40_CHARS
MISP_DB_PASSWORD=CHANGE_ME
MISP_DB_ROOT_PASSWORD=CHANGE_ME
MISP_URL=
# leave MISP_URL empty unless the backend should query this bundled MISP

# ── Velociraptor ──────────────────────────────────────────────────────────────
VELOCIRAPTOR_USER=admin
VELOCIRAPTOR_PASSWORD=CHANGE_ME

# ── Threat Intelligence (optional) ────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
LOCAL_LLM_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_EMBED_MODEL=nomic-embed-text

# ── Notifications (optional) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=socblitz@yourorg.com
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── SocBlitz unified agent deployment ────────────────────────────────────────
AGENT_ENROLL_KEY=CHANGE_ME
# Address endpoints use to reach this server — set to the host's real
# IP/DNS name so generated installers point agents at the load balancer.
AGENT_PUBLIC_HOST=
