# SocBlitz DISTRIBUTED — indexer node configuration (one per host)

# This node's identity — must match a name in certs.yml
NODE_NAME=wazuh-indexer-1

# This host's IP as seen by the other cluster nodes
PUBLISH_HOST=10.0.0.11

# All indexer host IPs, comma-separated (same value on every node)
SEED_HOSTS=10.0.0.11,10.0.0.12,10.0.0.13
INITIAL_MASTER_NODES=wazuh-indexer-1,wazuh-indexer-2,wazuh-indexer-3

# "yes" on wazuh-indexer-1 ONLY — runs securityadmin once after the cluster forms
SECURITY_INIT=no

# Heap = 50% of host RAM, never above -Xmx31g.
# 10k endpoints: 64 GB hosts → 31g / 32 GB hosts → 16g
INDEXER_HEAP=-Xms16g -Xmx16g

WAZUH_INDEXER_PASSWORD=CHANGE_ME
