# ─────────────────────────────────────────────────────────────────────────────
# SocBlitz DISTRIBUTED — app tier environment
# Copy to .env; replace every CHANGE_ME and every 10.0.0.x address.
# ─────────────────────────────────────────────────────────────────────────────

# ── SocBlitz application ──────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_ME_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIRST_ADMIN_EMAIL=admin@socblitz.local
FIRST_ADMIN_PASSWORD=CHANGE_ME

# ── PostgreSQL (this host) ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=socblitz
POSTGRES_USER=socblitz
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis (this host) ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# ── MinIO (this host) ─────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=socblitz
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_SECURE=false
MINIO_BUCKET_CASES=socblitz-cases
MINIO_BUCKET_REPORTS=socblitz-reports
MINIO_BUCKET_ARTIFACTS=socblitz-artifacts

# ── Wazuh cluster (EXTERNAL — the distributed Wazuh hosts) ────────────────────
# Indexer: any indexer node (reads are cluster-wide); Manager API: the MASTER.
WAZUH_INDEXER_URL=https://10.0.0.11:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME

WAZUH_MANAGER_URL=https://10.0.0.21:55000
WAZUH_MANAGER_USER=wazuh-wui
WAZUH_MANAGER_PASSWORD=CHANGE_ME

# ── MISP ──────────────────────────────────────────────────────────────────────
MISP_ADMIN_EMAIL=admin@admin.test
MISP_ADMIN_PASSWORD=CHANGE_ME
MISP_API_KEY=CHANGE_ME_40_CHARS
MISP_DB_PASSWORD=CHANGE_ME
MISP_DB_ROOT_PASSWORD=CHANGE_ME
MISP_URL=

# ── Velociraptor ──────────────────────────────────────────────────────────────
VELOCIRAPTOR_USER=admin
VELOCIRAPTOR_PASSWORD=CHANGE_ME

# ── Threat Intelligence (optional) ────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
LOCAL_LLM_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_EMBED_MODEL=nomic-embed-text

# ── Notifications (optional) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=socblitz@yourorg.com
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── SocBlitz unified agent deployment ────────────────────────────────────────
AGENT_ENROLL_KEY=CHANGE_ME
# Address endpoints use to download installers — this app host's public address
AGENT_PUBLIC_HOST=
